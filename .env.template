# ─────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA subas el .env a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────

# Ubicación / jerarquía para armar los tópicos MQTT.
# El tópico final queda: COUNTRY/STATE/CITY/INSTITUTION/MQTT_USER/{out,in}
# Con estos valores da exactamente: colombia/valle/tulua/univalle/sensor/out
COUNTRY=colombia
STATE=valle
CITY=tulua
INSTITUTION=univalle

# Broker MQTT (EMQX)
MQTT_SERVER=lermita.freeddns.org
# Puerto: 1883 (sin cifrar) u 8883 (TLS). Debe coincidir con MQTT_TLS.
MQTT_PORT=1883
MQTT_USER=sensor
MQTT_PASSWORD=PON_AQUI_LA_PASSWORD_DEL_USUARIO_SENSOR
# MQTT_TLS=0 -> conexión en texto plano (puerto 1883)
# MQTT_TLS=1 -> conexión cifrada TLS  (puerto 8883)
MQTT_TLS=0

# WiFi al que se conecta el ESP32 (necesita salida a internet).
WIFI_SSID=PON_AQUI_TU_RED_WIFI
WIFI_PASSWORD=PON_AQUI_LA_PASSWORD_WIFI
